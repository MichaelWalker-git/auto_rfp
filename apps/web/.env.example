# AWS Cognito Configuration
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=your-user-pool-id
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=your-client-id
NEXT_PUBLIC_COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com

# API Configuration
NEXT_PUBLIC_BASE_API_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com

# Environment
NEXT_PUBLIC_STAGE=Dev

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=Dev
# Sentry auth token for source map uploads
# Get from AWS: aws secretsmanager get-secret-value --secret-id "auto-rfp/sentry-auth-token" --query "SecretString" --output text
# Or from https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=

# Default temporary password for new users (shown in admin UI)
NEXT_PUBLIC_DEFAULT_TEMP_PASSWORD=Welcome1!

# Collaboration WebSocket API
NEXT_PUBLIC_WS_API_URL=wss://YOUR_WS_API_ID.execute-api.us-east-1.amazonaws.com/dev
