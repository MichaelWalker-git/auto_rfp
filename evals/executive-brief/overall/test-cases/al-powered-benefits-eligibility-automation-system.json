        "overview": "The City of Sacramento seeks to deploy an AI-powered benefits eligibility automation system integrated with their Salesforce Government Cloud environment. The selected vendor will provide a solution capable of processing structured application data and attached documentation to determine resident eligibility for the City's benefit programs, with a resident-facing status notification system and administrator dashboard.",
        "requirements": [
          {
            "category": "TECHNICAL",
            "mustHave": true,
            "requirement": "Design and implement an AI/ML eligibility screening engine capable of processing structured application data and attached documentation (income verification, lease agreements, utility bills)"
          },
          {
            "category": "TECHNICAL",
            "mustHave": true,
            "requirement": "Integrate the solution with Salesforce Government Cloud via certified Salesforce APIs"
          },
          {
            "category": "TECHNICAL",
            "mustHave": true,
            "requirement": "Implement a natural language processing (NLP) component to parse free-text application fields and extract structured eligibility data"
          },
          {
            "category": "DELIVERABLES",
            "mustHave": true,
            "requirement": "Provide a resident-facing status notification system (email and SMS) with multilingual support (English, Spanish, Vietnamese)"
          },
          {
            "category": "DELIVERABLES",
            "mustHave": true,
            "requirement": "Deliver an administrator dashboard with real-time case volume metrics, eligibility decision audit trail, and configurable program rules"
          },
          {
            "category": "COMPLIANCE",
            "mustHave": true,
            "requirement": "Design the data security architecture to meet City of Sacramento Information Security Policy v3.2 and California Consumer Privacy Act (CCPA) requirements"
          },
          {
            "category": "DELIVERABLES",
            "mustHave": true,
            "requirement": "Provide end-user training for City staff and a 60-day post-go-live support period"
          }
        ],
